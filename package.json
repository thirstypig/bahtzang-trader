{
  "name": "bahtzang-trader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev -- -p 3070",
    "dev:backend": "cd backend && uvicorn app.main:app --reload --port 4070",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && python3 -m pytest tests/ -v --tb=short",
    "test:backend:cov": "cd backend && python3 -m pytest tests/ --cov=app --cov-report=term-missing",
    "test:unit": "cd backend && python3 -m pytest tests/ -m unit -v",
    "test:integration": "cd backend && python3 -m pytest tests/ -m integration -v",
    "test:frontend": "cd frontend && npx vitest run",
    "docs:refresh": "node scripts/refresh-docs.mjs",
    "docs:inbox": "node scripts/sync-inbox.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
